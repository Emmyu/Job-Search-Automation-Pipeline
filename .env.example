PORT=3000
DATA_DIR=./data

# Comma-separated provider ids: remoteok, adzuna, mock
JOB_PROVIDERS=remoteok,mock

# Adzuna (https://developer.adzuna.com/) — optional
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Cron schedule for automatic searches (empty = disabled)
# Example: every day at 8am — 0 8 * * *
SEARCH_CRON=

# Default search criteria (overridable via API)
DEFAULT_KEYWORDS=typescript,node,backend
DEFAULT_LOCATION=
DEFAULT_REMOTE_ONLY=false
MIN_MATCH_SCORE=40
